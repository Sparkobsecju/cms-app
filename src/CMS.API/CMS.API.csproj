<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Dapper" Version="2.1.79" />
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="9.0.16" />
    <PackageReference Include="Microsoft.Data.SqlClient" Version="7.0.2" />
    <PackageReference Include="PDFsharp-MigraDoc" Version="6.1.1" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="7.2.0" />
  </ItemGroup>

  <!-- CJK-capable font (SIL OFL) embedded so the Core PDFsharp build can render
       Traditional Chinese course content without depending on host fonts. -->
  <ItemGroup>
    <EmbeddedResource Include="Assets\Fonts\NotoSansTC-VF.ttf" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="CMS.API.Tests" />
  </ItemGroup>

</Project>
